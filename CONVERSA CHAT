import {
  IconDashboard, IconCalendar, IconSettings, IconList, IconZap,
  IconFolder, IconHash, IconNeural, IconFileText
} from '@/components/icons/PranaLandscapeIcons';


const PANELS = [
    { id: 'files', icon: IconFolder, label: 'Explorer' },
    { id: 'tags', icon: IconHash, label: 'Tags' }
];


const MAIN_VIEWS = [
  { type: VIEW_TYPES.DASHBOARD, icon: IconDashboard, label: "Painel" },
  { type: VIEW_TYPES.PLANNER_WEEKLY, icon: IconList, label: "Planejador" },
  { type: VIEW_TYPES.CALENDAR_MONTHLY, icon: IconCalendar, label: "Calendário" },
];


export default function Sidebar({ className, activePanel, onPanelChange }) {
  const { openTab, tabGroups, layout, toggleExplorer } = useWorkspaceStore();
  const activeTabId = tabGroups.main.activeId;
  const activeTabType = tabGroups.main.tabs.find(t => t.id === activeTabId)?.type;


  const handlePanelClick = (panelId) => {
      if (activePanel === panelId && layout.explorer.open) {
          toggleExplorer();
      } else {
          if (!layout.explorer.open) toggleExplorer();
          onPanelChange(panelId);
      }
  };


  const handleCreate = (context = null) => {
      window.dispatchEvent(new CustomEvent('prana:open-smart-modal', {
          detail: { context }
      }));
  };


  return (
    <div className={cn("h-full flex flex-col py-3 items-center w-full gap-3", className)}>
     
      {/* 1. MANIFESTAR (IA GERAL) */}
      <div>
          <button
            onClick={() => handleCreate()}
            className="group relative flex items-center justify-center w-10 h-10 rounded-xl bg-primary/20 text-primary border border-primary/30 hover:bg-primary/30 hover:scale-105 hover:shadow-[0_0_15px_rgba(var(--primary-rgb),0.3)] transition-all duration-300"
            title="Manifestar com Ash (Ctrl+K)"
          >
            <IconZap className="w-5 h-5" />
          </button>
      </div>


       {/* 2. CRIAÇÃO RÁPIDA */}
      <div className="flex flex-col gap-1 w-full items-center pb-3 border-b border-white/10">
          {/* Faísca */}
          <button onClick={() => handleCreate('spark')} className="p-2 text-yellow-400/70 hover:text-yellow-400 hover:bg-white/5 rounded-lg transition-all" title="Nova Ideia">
              <IconNeural className="w-5 h-5" />
          </button>
         
          {/* Tarefa */}
          <button onClick={() => handleCreate('task')} className="p-2 text-emerald-400/70 hover:text-emerald-400 hover:bg-white/5 rounded-lg transition-all" title="Nova Tarefa">
              <IconList className="w-5 h-5" />
          </button>
         
          {/* [NOVO] Projeto */}
          <button onClick={() => handleCreate('project')} className="p-2 text-purple-400/70 hover:text-purple-400 hover:bg-white/5 rounded-lg transition-all" title="Novo Projeto">
              <IconLayers className="w-5 h-5" />
          </button>


          {/* Doc */}
          <button onClick={() => handleCreate('doc')} className="p-2 text-blue-400/70 hover:text-blue-400 hover:bg-white/5 rounded-lg transition-all" title="Novo Documento">
              <IconFileText className="w-5 h-5" />
          </button>
      </div>




      {/* 3. PAINÉIS LATERAIS (Explorer/Tags) */}
      <div className="flex flex-col gap-1 w-full items-center mt-2">
          {PANELS.map(panel => {
              const isActive = activePanel === panel.id && layout.explorer.open;
              const Icon = panel.icon;
              return (
                <button
                    key={panel.id}
                    onClick={() => handlePanelClick(panel.id)}
                    className={cn(
                        "p-2 rounded-md transition-all relative group w-10 h-10 flex items-center justify-center",
                        isActive ? "text-white bg-white/10" : "text-gray-500 hover:text-white hover:bg-white/5"
                    )}
                    title={panel.label}
                >
                    <Icon className="w-5 h-5" />
                    {isActive && <div className="absolute left-0 top-1 bottom-1 w-[3px] bg-primary rounded-r-full" />}
                </button>
              );
          })}
      </div>


      <div className="w-8 h-[1px] bg-white/10 my-1" />


      {/* 4. VISTAS PRINCIPAIS */}
      <div className="flex-1 flex flex-col gap-1 w-full items-center overflow-y-auto no-scrollbar">
          {MAIN_VIEWS.map((item) => {
            const Icon = item.icon;
            const isActive = activeTabType === item.type;
            return (
              <button
                key={item.type}
                onClick={() => openTab({ type: item.type, title: item.label }, 'main')}
                className={cn(
                  "p-2 rounded-md transition-all relative group w-10 h-10 flex items-center justify-center",
                  isActive ? "text-primary bg-primary/10" : "text-gray-500 hover:text-white hover:bg-white/5"
                )}
                title={item.label}
              >
                <Icon className={cn("w-5 h-5 transition-transform", isActive && "scale-110")} />
              </button>
            );
          })}
      </div>


      {/* 5. CONFIGURAÇÃO */}
      <div className="mt-auto flex flex-col gap-2 items-center pt-2 border-t border-white/5 w-full">
         <button
            onClick={() => openTab({ type: VIEW_TYPES.SETTINGS, title: 'Configurações' }, 'main')}
            className={cn(
              "w-10 h-10 flex items-center justify-center rounded-md text-gray-500 hover:text-white hover:bg-white/5 transition-all",
              activeTabType === VIEW_TYPES.SETTINGS && "text-primary"
            )}
         >
           <IconSettings className="w-5 h-5" />
         </button>
      </div>
    </div>
  );
}


